#!/usr/bin/php
<?php
/////////////////////////////////////////////////////////////////////////////
// restore_pipewire_volumes
//
// Restores PipeWire audio group and per-member volume levels from the
// JSON configuration.  Called by FPPINIT after PipeWire has fully started
// (and after regenerate_pipewire_groups) so that WirePlumber's stale
// volume state is overridden with the user-configured values.
/////////////////////////////////////////////////////////////////////////////

$SUDO = "";
if (posix_getuid() !== 0) {
    $SUDO = "sudo";
}

$settings = array();
$settingsFile = "/home/fpp/media/settings";
if (file_exists($settingsFile)) {
    $lines = file($settingsFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line) || $line[0] === '#')
            continue;
        if (strpos($line, '=') !== false) {
            list($key, $value) = explode('=', $line, 2);
            $key = trim($key);
            $value = trim($value, " \t\n\r\0\x0B\"'");
            $settings[$key] = $value;
        }
    }
}
if (!isset($settings['mediaDirectory']))
    $settings['mediaDirectory'] = '/home/fpp/media';

$fppDir = isset($settings['fppDir']) ? $settings['fppDir'] : '/opt/fpp';
chdir($fppDir . '/www/api');

ob_start();
$_SERVER['REQUEST_URI'] = '/api/pipewire';
$_SERVER['PHP_SELF'] = 'restore_pipewire_volumes';

if (!function_exists('json')) {
    function json($data)
    {
        return json_encode($data);
    }
}

require_once $fppDir . '/www/common.php';
require_once $fppDir . '/www/api/controllers/pipewire.php';
ob_end_clean();

RestorePipeWireGroupVolumes();
