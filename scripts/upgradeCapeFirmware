#!/usr/bin/php
<?php

$newFirmwareFile = '';
$force = false;
$resetDefaults = false;

// Parse all flags and the firmware filename from command line arguments
for ($i = 1; $i < $argc; $i++) {
    if ($argv[$i] == 'force') {
        $force = true;
    } else if ($argv[$i] == 'resetDefaults') {
        $resetDefaults = true;
    } else {
        $newFirmwareFile = $argv[$i];
    }
}

$fppcapedetectFlags = $resetDefaults ? " -force-defaults" : "";

// Walk the EEPROM data sections and locate the signature section (code 99)
// and the end-of-data terminator.  Returns:
//   sig_offset: byte offset of the code 99 length tag, or null if no signature
//   end_offset: byte offset right after the trailing 0-length terminator
function find_eeprom_offsets($data)
{
    $dataLen = strlen($data);
    if ($dataLen < 64) {
        return ['sig_offset' => null, 'end_offset' => $dataLen];
    }

    $pos = 58; // skip fixed header (format + capeName + capeVersion + capeSerial)
    $sigOffset = null;
    while ($pos + 8 <= $dataLen) {
        $len = intval(substr($data, $pos, 6));
        if ($len == 0) {
            return ['sig_offset' => $sigOffset, 'end_offset' => $pos + 6];
        }
        $flag = intval(substr($data, $pos + 6, 2));
        if ($sigOffset === null && $flag == 99) {
            $sigOffset = $pos;
        }
        $advance = 8 + $len;
        if ($flag < 50) {
            // file sections include a 64-byte filename in addition to $len bytes of data
            $advance += 64;
        }
        $pos += $advance;
    }

    return ['sig_offset' => $sigOffset, 'end_offset' => $dataLen];
}

$eepromFile = "/sys/bus/i2c/devices/1-0050/eeprom";
if (file_exists("/home/fpp/media/tmp/eeprom_location.txt")) {
    $eepromFile = file_get_contents("/home/fpp/media/tmp/eeprom_location.txt");
    if ($eepromFile == "/sys/bus/i2c/devices/1-0050/eeprom") {
        file_put_contents("/sys/bus/i2c/devices/i2c-1/new_device", "24c256 0x50");
    } else if ($eepromFile == "/sys/bus/i2c/devices/2-0050/eeprom") {
        file_put_contents("/sys/bus/i2c/devices/i2c-2/new_device", "24c256 0x50");
    }
    usleep(100000);
}
if (!file_exists($eepromFile)) {
    $eepromFile = '/home/fpp/media/config/cape-eeprom.bin';
    if (!file_exists($eepromFile)) {
        if (preg_match('/^\/opt\/fpp\/capes/', $newFirmwareFile)) {
            echo "Installing new virtual EEPROM.\n";
            copy($newFirmwareFile, $eepromFile);
            chown($eepromFile, 'fpp');
            chgrp($eepromFile, 'fpp');
            chmod($eepromFile, 0644);

            echo "======================\n";
            echo "Running fppcapedetect:\n\n";

            system("/opt/fpp/src/fppcapedetect" . $fppcapedetectFlags);
            echo "\nFinished, please reboot.\n";
            return 0;
        } else {
            echo "Could not find EEPROM.  Is Cape mounted and FPP rebooted?\n";
            return 1;
        }
    }
}

//backup the old firmware
$date = new DateTime();
$timestamp = date_format($date, 'Ymd-His');
$backupFile = "/home/fpp/media/upload/cape-eeprom-Backup-" . $timestamp . ".bin";

//copy($newFirmwareFile, "/home/fpp/media/upload/cape-firmware-new.bin");

$olddata = fopen($eepromFile, 'r+b');
set_file_buffer($olddata, 32768);
$oldheader = trim(fread($olddata, 6)); // should be FPP02 + null
if ($oldheader != "FPP02") {
    //first 4 bytes are 0xFF, assume blank eeprom and just write what we have
    echo "Blank EEPROM, overwriting";
    fclose($olddata);
    copy($newFirmwareFile, $eepromFile);

    if ($eepromFile == '/home/fpp/media/config/cape-eeprom.bin') {
        chown($eepromFile, 'fpp');
        chgrp($eepromFile, 'fpp');
        chmod($eepromFile, 0644);
    }

    echo "======================\n";
    echo "Running fppcapedetect:\n\n";
    system("/opt/fpp/src/fppcapedetect" . $fppcapedetectFlags);
    echo "\nFinished, please reboot.\n";
    return 0;
}

$newdata = fopen($newFirmwareFile, 'rb');

$oldcape = trim(fread($olddata, 26)); // cape name + nulls
$oldcapev = trim(fread($olddata, 10)); // cape version + nulls

$newheader = trim(fread($newdata, 6)); // should be FPP02 + null
$newcape = trim(fread($newdata, 26)); // cape name + nulls
$newcapev = trim(fread($newdata, 10)); // cape version + nulls

$missmatch = false;
if ($oldcape != $newcape || $oldcapev != $newcapev) {
    if ($force) {
        copy($eepromFile, $backupFile);
        chown($backupFile, 'fpp');
        chgrp($backupFile, 'fpp');
        chmod($backupFile, 0644);

        echo "Overwriting cape firmware.\n";
        echo "Cape: " . $oldcape . "   Version: " . $oldcapev . "\n";
        echo "Firmware: " . $newcape . "   Version: " . $newcapev . "\n";
        $missmatch = true;
        fseek($olddata, 6, SEEK_SET);
        fwrite($olddata, pack("a26", $newcape));
        fwrite($olddata, pack("a10", $newcapev));
        fflush($olddata);
    } else {
        echo "Cape does not match new firmware.\n";
        echo "Cape: " . $oldcape . "   Version: " . $oldcapev . "\n";
        echo "Firmware: " . $newcape . "   Version: " . $newcapev . "\n";
        return 1;
    }
} else {
    echo "Found Cape: " . $oldcape . "   Version: " . $oldcapev . "\n";

    copy($eepromFile, $backupFile);
    chown($backupFile, 'fpp');
    chgrp($backupFile, 'fpp');
    chmod($backupFile, 0644);
}

//skip over the serial number
$newcapesn = trim(fread($newdata, 16)); // cape serial# + nulls
$oldcapesn = trim(fread($olddata, 16)); // cape serial# + nulls
if (($eepromFile == '/home/fpp/media/config/cape-eeprom.bin') && preg_match('/^0*$/', $oldcapesn) && ($oldcape == $newcape)) {
    fseek($olddata, -16, SEEK_CUR);
    fwrite($olddata, pack("a16", $newcapesn));
}

$flen = fread($olddata, 6); //length of the section
$flen = intval($flen);
while ($flen != 0) {
    $flags = fread($olddata, 2);
    if ($flags == 97) {
        fread($olddata, $flen);
        $fpos = ftell($olddata);
        $flen = fread($olddata, 6); //length of the section
        $flen = intval($flen);
        if ($flen == 0) {
            fseek($olddata, $fpos, SEEK_SET);
        }
    } else {
        fseek($olddata, -8, SEEK_CUR);
        $flen = 0;
    }
}

$flen = fread($newdata, 6); //length of the section
$flen = intval($flen);
while ($flen != 0) {
    $flags = fread($newdata, 2);
    if ($flags != 97) {
        fwrite($olddata, pack("a6", $flen));
        fwrite($olddata, pack("a2", $flags));
        if ($flags < 50) {
            $fname = fread($newdata, 64);
            fwrite($olddata, $fname);
        }

        $data = fread($newdata, $flen);
        fwrite($olddata, $data);
    } else {
        fread($newdata, $flen);
    }
    $flen = fread($newdata, 6); //length of the section
    $flen = intval($flen);
}
fwrite($olddata, pack("a6", "0"));

fclose($newdata);
fclose($olddata);

// Issue #1314: If the previous EEPROM was signed and the new EEPROM image does
// not contain its own signature, inherit the signature section from the
// previous EEPROM so that the user does not need to re-sign their cape after
// every EEPROM upgrade.  The signature only covers the bytes within the signed
// section itself, so splicing those bytes verbatim into the new EEPROM keeps
// the signature cryptographically valid.
if (file_exists($backupFile)) {
    $origData = file_get_contents($backupFile);
    if ($origData !== false && strlen($origData) >= 64 && substr($origData, 0, 5) === 'FPP02') {
        $origInfo = find_eeprom_offsets($origData);
        if ($origInfo['sig_offset'] !== null) {
            $upgradedData = file_get_contents($eepromFile);
            if ($upgradedData !== false) {
                $upgInfo = find_eeprom_offsets($upgradedData);
                if ($upgInfo['sig_offset'] === null && $upgInfo['end_offset'] >= 6) {
                    // Splice in the previous signature section in place of the
                    // upgraded EEPROM's terminator (which sits at end_offset - 6).
                    $insertPos = $upgInfo['end_offset'] - 6;
                    $signedTail = substr(
                        $origData,
                        $origInfo['sig_offset'],
                        $origInfo['end_offset'] - $origInfo['sig_offset']
                    );
                    $sfh = fopen($eepromFile, 'r+b');
                    if ($sfh) {
                        set_file_buffer($sfh, 32768);
                        fseek($sfh, $insertPos, SEEK_SET);
                        fwrite($sfh, $signedTail);
                        fflush($sfh);
                        fclose($sfh);
                        echo "Preserved signature section from previous EEPROM.\n";
                    }
                }
            }
        }
    }
}

echo "Upgrade Complete\n\n";
echo "======================\n";
echo "Running fppcapedetect:\n\n";

system("/opt/fpp/src/fppcapedetect" . $fppcapedetectFlags);

echo "\nFinished, please reboot.\n";

